RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Bloquear bots de scraping e IA
RewriteCond %{HTTP_USER_AGENT} (semrush|ahref|mj12bot|dotbot|GPTBot|CCBot|ClaudeBot|Google-Extended) [NC]
RewriteRule .* - [F,L]

# Bloquear directorios sensibles
RedirectMatch 403 /\.git(/|$)
RedirectMatch 403 /\.opencode(/|$)
RedirectMatch 403 /\.vscode(/|$)

<IfModule mod_headers.c>
  # HSTS — fuerza HTTPS por 1 año
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  
  Header set X-XSS-Protection "1; mode=block"
  Header always append X-Frame-Options SAMEORIGIN
  Header set X-Content-Type-Options nosniff
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "accelerometer=(self), autoplay=(self), camera=(), gyroscope=(self), magnetometer=(), microphone=(), usb=()"
  
  # CSP canónica v4.1 — con frame-ancestors y form-action
  Header set Content-Security-Policy "default-src 'self'; img-src 'self' data: blob:; media-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://assets.calendly.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://assets.calendly.com; font-src https://fonts.gstatic.com; connect-src 'self' https://api.themisbynexus.com https://calendly.com; frame-src https://www.youtube.com https://calendly.com; frame-ancestors 'self'; form-action 'self'; object-src 'none'; base-uri 'self';"
  
  # COOP / CORP — aislamiento de contexto
  Header set Cross-Origin-Opener-Policy "same-origin"
  Header set Cross-Origin-Resource-Policy "same-origin"
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 month"
  ExpiresByType video/webm "access plus 1 month"
  ExpiresByType audio/mp4 "access plus 1 year"
  ExpiresByType audio/mpeg "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|png|jpe?g|webp|woff2)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
  <FilesMatch "\.(mp4|webm|webp|m4a)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml font/woff2
</IfModule>

# HOTFIX: Asegurar MIME type correcto para videos MP4
<IfModule mod_mime.c>
  AddType video/mp4 .mp4
  AddType audio/mp4 .m4a
</IfModule>

Options -Indexes

<FilesMatch "(?i)\.(env|ini|log|sh|bak|sql|md|git|DS_Store)$">
  Require all denied
</FilesMatch>

ErrorDocument 404 /index.html
